SKSHU_BI_API_KEY=填写你的apikey
# 可选：不填则使用默认开发环境接口
# SKSHU_EMPLOYEE_INDEX_CCQ_API_URL=https://apidev.skshu.com/test/skshu-bi-api/biapitoxt/getEmployeeIndexAiCcq

# 大模型配置：真实密钥只填写在 .env 或服务器 Secret 中
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat
AI_API_KEY=填写你的大模型apikey
AI_REQUIRED=true
AI_TIMEOUT_SECONDS=120
AI_MAX_RETRIES=2
AI_PROMPT_VERSION=report-narrative-bundle-v1
